# ============================================================
# InfluenceAI — Environment Variables
# ============================================================

# Google Gemini API Key (optional)
# Get yours at: https://aistudio.google.com/apikey
# If not set, AI features will use intelligent template generation.
VITE_GEMINI_API_KEY=

# ============================================================
# Production Database (for Next.js deployment)
# ============================================================
# DATABASE_URL=mysql://user:password@localhost:3306/influenceai
# JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
# BCRYPT_SALT_ROUNDS=12
